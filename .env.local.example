GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=your-calendar-id@gmail.com

# ElevenLabs Conversational AI — /api/elevenlabs/signed-url + /elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
